{
  "name": "interplanet/time",
  "description": "PHP library for interplanetary time calculations — ported from planet-time.js",
  "version": "0.1.0",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "InterplanetTime\\": "src/InterplanetTime/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "InterplanetTime\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit tests/"
  },
  "minimum-stability": "stable"
}
